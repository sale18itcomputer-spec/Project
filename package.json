{
  "name": "limperial-project-dashboard",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "mcp": "ts-node --transpile-only src/mcp.ts",
    "mcp:start": "PORT=${PORT:-8080} ts-node --transpile-only src/mcp.ts",
    "dev": "next dev --turbopack --port 3001",
    "dev:full": "concurrently --names \"next,cloudflared,webhook\" --prefix-colors \"cyan,magenta,green\" \"next dev --turbopack --port 3001\" \"cloudflared tunnel --url http://localhost:3001 2>&1 | tee .cloudflared-url\" \"node auto-webhook.mjs\"",
    "webhook": "node auto-webhook.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:deposit-percent": "node scripts/regression-deposit-percent.ts",
    "clean:imports": "eslint . --fix",
    "clean:files": "knip"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@google/genai": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
