  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "ansi-html": "^0.0.9",
    "json5": "^2.2.3",
    "semver": "^7.5.4",
    "tough-cookie": "^4.1.3",
    "word-wrap": "^1.2.4",
    "uuid": "^11.1.1",
    "postcss": "^8.5.10"
  }
