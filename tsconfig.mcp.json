{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "dist-mcp",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "noEmitOnError": false
  },
  "include": ["src/mcp.ts"],
  "exclude": ["node_modules"]
}
