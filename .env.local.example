# ─────────────────────────────────────────────────────────────
# AI Assistant — self-hosted, LAN-only. The whole team uses the same locally
# hosted models because the app calls them SERVER-SIDE: any staff member using
# the web app automatically goes through these, no per-user setup, no cloud.
#
# Copy these lines into your real .env.local (gitignored) on the machine that
# RUNS the app server, and fill in the two keys. That machine must be on the
# same LAN as the Ollama server (192.168.10.131).
# ─────────────────────────────────────────────────────────────

# Plain chat → the authed server.js gateway in front of Ollama
AI_PROXY_URL=http://192.168.10.131:3000
AI_PROXY_KEY=<the x-api-key your server.js checks>

# Agent tool-calling + embeddings → Ollama native API (direct, LAN)
AI_OLLAMA_URL=http://192.168.10.131:11434
AI_EMBED_MODEL=nomic-embed-text          # pull once on the server: ollama pull nomic-embed-text

# Agent → LPT MCP server (the ~50 procurement/sales tools)
AGENT_MCP_URL=http://192.168.10.131:8080/mcp
AGENT_MCP_KEY=<the MCP server's MCP_API_KEY>

# Optional: self-hosted SearXNG for web_search (else a no-key DuckDuckGo fallback is used)
# SEARXNG_URL=http://192.168.10.131:8888
